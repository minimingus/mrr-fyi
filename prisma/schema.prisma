generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Founder {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  twitter     String?
  productName String
  productUrl  String
  description String?
  category    FounderCategory?
  email            String?
  updateToken      String?  @unique
  emailVerified    Boolean  @default(false)
  emailVerifyToken String?  @unique
  referralCode     String?  @unique
  referredBy       String?
  onboardingStep   Int      @default(0)
  mrr         Int
  currency    String        @default("USD")
  verified    Boolean       @default(false)
  featured    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  snapshots   MRRSnapshot[]
  payments    Payment[]
  milestones  MRRMilestone[]
  referralsMade    Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referred")

  @@index([mrr(sort: Desc)])
  @@index([featured])
}

model MRRSnapshot {
  id         String   @id @default(cuid())
  founderId  String
  mrr        Int
  recordedAt DateTime @default(now())

  founder Founder @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@index([founderId, recordedAt])
}

model Payment {
  id            String      @id @default(cuid())
  founderId     String
  type          PaymentType
  externalId    String      @unique
  active        Boolean     @default(true)
  trialEndsAt        DateTime?
  trialReminder      Boolean     @default(false)
  trialExpiredNotice Boolean     @default(false)
  createdAt          DateTime    @default(now())

  founder Founder @relation(fields: [founderId], references: [id], onDelete: Cascade)
}

model MRRMilestone {
  id        String   @id @default(cuid())
  founderId String
  amount    Int
  reachedAt DateTime @default(now())

  founder Founder @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@unique([founderId, amount])
  @@index([founderId])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  createdAt   DateTime @default(now())

  referrer Founder @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred Founder @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referrerId])
}

enum PaymentType {
  FEATURED
  VERIFIED
}

enum FounderCategory {
  SAAS
  ECOMMERCE
  AGENCY
  CREATOR
  MARKETPLACE
  DEV_TOOLS
  OTHER
}
